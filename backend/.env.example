# ===========================================
# AcessoLivre Backend - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e configure os valores

# Banco de Dados PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/acessolivre
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=sua_senha_aqui

# JWT Secret (usado para assinar tokens - NÃO compartilhe)
JWT_SECRET=sua_chave_secreta_jwt_aqui

# Admin Bootstrap Secret (usado apenas para criar primeiro admin)
# Gere um valor forte com: openssl rand -base64 32
# Após criar o admin, você pode remover esta variável por segurança
ADMIN_BOOTSTRAP_SECRET=seu_segredo_bootstrap_aqui

# Email Configuration (placeholder - configure quando implementar)
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=example@example.com
SPRING_MAIL_PASSWORD=senha_email_aqui

# Application Settings
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
