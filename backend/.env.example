# Server
SERVER_PORT=8080

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5173

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/acessolivre
SPRING_DATASOURCE_DRIVER=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=sua_senha_aqui

POSTGRES_DB=acessolivre
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_aqui

# JPA
JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true

# H2
H2_CONSOLE_ENABLED=false

# JWT
JWT_PUBLIC_KEY=classpath:app.pub
JWT_PRIVATE_KEY=classpath:app.key
JWT_TOKEN_EXPIRATION_DEFAULT=3600
JWT_TOKEN_EXPIRATION_REMEMBER_ME=604800

# Admin Bootstrap
ADMIN_BOOTSTRAP_SECRET=seu_segredo_bootstrap_aqui

# Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu_email@gmail.com
MAIL_PASSWORD=sua_senha_de_app
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_SSL_TRUST=*
MAIL_FROM=noreply@acessolivre.com.br

# DevTools
SPRING_DEVTOOLS_ENABLED=true
SPRING_LIVERELOAD_ENABLED=true

# Logging
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_SPRING=INFO
LOG_LEVEL_HIBERNATE=WARN
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SCHEDULER=INFO

# Profile
SPRING_PROFILES_ACTIVE=dev
