# Ambiente (dev/prod)
ENVIRONMENT=dev

# URLs da API Backend
# Para desenvolvimento local (web)
WEB_API_URL=http://localhost:8080/api

# Para emulador Android (10.0.2.2 é o localhost do host no emulador Android)
ANDROID_API_URL=http://10.0.2.2:8080/api

# Para simulador iOS ou dispositivo físico (use o IP da sua máquina na rede local)
IOS_API_URL=http://192.168.1.100:8080/api

# URL de produção (substitua pelo seu domínio quando for para produção)
PROD_API_URL=https://api.acessolivre.com/api
